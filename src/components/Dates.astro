---
import { contentfulClient } from "../lib/contentful";

const entries = await contentfulClient.getEntries({
    content_type: 'dates',
    order: 'fields.date' as any,
});


// limpiamos datos para usarlos mas facil
// mapeamos los resultados para quedarnos con los campos que nos importan
const DAYS_TO_SHOW_TICKETS = 30;

const shows = entries.items.map((item:any) => {
    const {venue, date, city, address, ticketLink, mapLink} = item.fields;
    
    const showDate = new Date(date);
    const today = new Date();

    const diffTime = showDate.getTime() - today.getTime();
    const diffDays = Math.ceil(diffTime / (1000*60*60*24) );
    const isPast = diffDays < 0;

    const showTicketButton = ticketLink && diffDays <= DAYS_TO_SHOW_TICKETS && !isPast;

    //logica para el mapa, si lo cargamos usa el cargado, de lo contrario junta data para que Google lo busque
    const autoMapQuery = `${venue || ''} ${address || ''} ${city || ''}`.trim();
    const finalMapUrl = mapLink ? mapLink : `https://maps.google.com/?q=${encodeURIComponent(autoMapQuery)}`;
    
    return {
        date: showDate,
        day: showDate.getDate().toString().padStart(2, '0'),
        month: showDate.toLocaleString('es-AR', {month: 'short'}).toUpperCase().replace('.', ''),
        time: showDate.getHours().toString().padStart(2, '0') + ':' +showDate.getMinutes().toString().padStart(2, '0'),
        venue, 
        city,
        ticketLink,
        mapUrl: finalMapUrl,
        showTicketButton,
        isPast 
    };
});

---



<div id="fechas" class="section dates">
    <div class="main-container">
    <h2 class="section-title">Próximas Fechas</h2>

    <div class="show-list">
        {shows.map( (show)=> (
            <article class={`show-card ${show.isPast ? 'past-show' : ''}`}>

                <div class="date-box">
                    <span class="day">{show.day}</span>
                    <span class="month">{show.month}</span>
                </div>

                <div class="show-info">
                    <span class="show-venue">{show.venue}</span>
                    <span class="show-city-time">{show.city ? `${show.city} • `: ''}{show.time} Hs</span>
                </div>
                <div>
                    {!show.isPast && ( 
                        <a href={show.mapUrl}
                        target="_blank"
                        class="btn-map"
                        rel="noopener noreferrer" >
                            Cómo llegar
                        </a>
                    )}

                </div>

                <div class="show-actions">
                    {show.isPast ? ( 
                        <span class="past-show-label">¡Gracias por venir!</span>
                    ) : show.showTicketButton ? ( 
                        <a href={show.ticketLink}
                        target="_blank"
                        class="btn-tickets" >
                            Entradas
                        </a>
                    ) : ( 
                        <span class="coming-soon">Próximamente...</span>
                    )}
                </div>
                
            </article>

        ))}
        {shows.length === 0 && (
            <p class="no-shows">No hay fechas confirmadas por el momento.¡Atentos a las redes!</p>
        )}
    </div>
</div>
</section>

<style>


.show-list {
    display: flex;
    flex-direction: column;
    gap: 1.rem;
    max-width: 800px;
    margin: auto;
}

.show-card {
    display: flex;
    align-items: center;
    background: var(--color-bg-card);
    border: 1px solid #333;
    padding: 1.5rem;
    border-radius: 2px;
    gap: 2rem;
    transition: var(--transition-fast, all 0.3s ease);
}

.show-card:hover {
    border-color: var(--color-brown-solid);
    transform: translateX(5px);
}

.past-show {
    opacity: 0.5;
    pointer-events: none;
    filter: grayscale(1);
}

.date-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-base);
    padding: 0.8rem;
    min-width: 80px;
    border-radius: 2px;
    border: 1px solid var(--color-brown-solid);
}

.day {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color-text-main);
    line-height: 1;
}

.month {
    font-size: 0.9rem;
    text-transform: uppercase;
    color: var(--color-text-main);
    font-weight: 700;
}

.show-info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex-grow: 1;
}

.show-location {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text-main);
    text-transform: uppercase;
}

.show-time {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    text-transform: capitalize;
}

/*Boton mapa*/
.btn-map {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    text-decoration: none;
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color 0.3s;
    width: fit-content;
}

.btn-map:hover {
    color: var(--color-brown-solid);
    text-decoration: underline;
}

.show-actions {
    min-width: 180px;
    text-align: right;
}

.btn-tickets {
    display: inline-block;
    background: var(--color-brown-light);
    border: 1px solid var(--color-brown-solid);
    color: var(--color-text-main);
    padding: 0.8rem 1.5rem;
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: var(--transition-fast, all 0.3s ease);
}

.btn-tickets:hover {
    background: var(--color-text-muted);
    color: var(--color-text-main);
    box-shadow: 0 0 15px rgba(97, 69, 58,0.4);
}

.coming-soon {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.no-shows {
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
    padding: 3rem;
    border: 1px dashed rgba(255, 255, 255, 0.2);
    border-radius: 42px;
}

@media (max-width: 600px) {
    .show-card {
        flex-direction: column;
        text-align: center;
        gap: 1rem;
        padding: 2rem 1.5rem;

    }

    .show-info {
        align-items: center;
        width: 100%;
    }
    .date-box {
        width: 100%;
        flex-direction: row;
        gap: 1rem;
        padding: 0.5rem;
    }

    .day {
        font-size: 1.5rem;
    }
    
    .show-actions {
        width: 100%;
        text-align: center;
    }

    .btn-tickets {
        width: 100%;
    }

}

</style>