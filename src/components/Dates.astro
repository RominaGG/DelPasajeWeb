---
import { contentfulClient } from "../lib/contentful";

const entries = await contentfulClient.getEntries({
    content_type: 'dates',
    order: 'fields.date' as any,
});


// limpiamos datos para usarlos mas facil
// mapeamos los resultados para quedarnos con los campos que nos importan
const DAYS_TO_SHOW_TICKETS = 30;

const shows = entries.items.map((item:any) => {
    const {venue, date, city, address, ticketLink, mapLink} = item.fields;
    
    const showDate = new Date(date);
    const today = new Date();

    const diffTime = showDate.getTime() - today.getTime();
    const diffDays = Math.ceil(diffTime / (1000*60*60*24) );

    const showTicketButton = ticketLink && diffDays <= DAYS_TO_SHOW_TICKETS;

    //logica para el mapa, si lo cargamos usa el cargado, de lo contrario junta data para que Google lo busque
    const autoMapQuery = `${venue || ''} ${address || ''} ${city || ''}`.trim();
    const finalMapUrl = mapLink ? mapLink : `https://maps.google.com/?q=${encodeURIComponent(autoMapQuery)}`;
    
    return {
        date: showDate,
        day: showDate.getDate().toString().padStart(2, '0'),
        month: showDate.toLocaleString('es-AR', {month: 'short'}).toUpperCase().replace('.', ''),
        time: showDate.getHours().toString().padStart(2, '0') + ':' +showDate.getMinutes().toString().padStart(2, '0'),
        venue, 
        city,
        ticketLink,
        mapUrl: finalMapUrl,
        showTicketButton,
        isPast: diffDays < 0 
    };
});

---



<div id="fechas" class="section dates">
    <div class="main-container">
    <h2 class="section-title">Próximas Fechas</h2>

    <div class="show-list">
        {shows.map( (show)=> (
            <article class={`show-card ${show.isPast ? 'past-show' : ''}`}>

                <div class="date-box">
                    <span class="day">{show.day}</span>
                    <span class="month">{show.month}</span>
                </div>

                <div class="show-info">
                    <span class="show-venue">{show.venue}</span>
                    <span class="show-city-time">{show.city ? `${show.city} • `: ''}{show.time} Hs</span>
                </div>
                <div>
                <a href={show.mapUrl} 
                target="_blank"
                class="btn-map"
                rel="noopener noreferrer">
                    Cómo llegar
                </a>
                </div>

                <div class="show-actions">
                    {show.showTicketButton ? (
                        <a href={show.ticketLink}
                        target="_blank"
                        class="btn-tickets">
                            Entradas
                        </a>
                    ) : (
                        !show.isPast && <span class="coming-soon">Próximamente</span>
                    )}
                </div>
            </article>

        ))}
        {shows.length === 0 && (
            <p class="no-shows">No hay fechas confirmadas por el momento.¡Atentos a las redes!</p>
        )}
    </div>
</div>
</section>

