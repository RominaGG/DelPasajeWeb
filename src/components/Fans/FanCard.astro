---
import {Image} from 'astro:assets';
const { post } = Astro.props;

---

<li class="fan-card">
  <div class="card-image">
    {
      post.image ? (
        <Image 
        src={post.image} 
        alt={`Foto de ${post.name}`}
        inferSize= {true} 
        loading="lazy" />
      ) : (
        <div class="placeholder-img">🤘</div>
      )
    }
  </div>

  <div class="card-content">
    <blockquote class="fan-message">{post.message}</blockquote>
    <div class="fan-footer">
      <span class="fan-name">{post.name}</span>
      {
        post.instagram && (
          <a
            href={`https://instagram.com/${post.instagram.replace("@", "")}`}
            target="_blank"
            rel="noopener noreferrer"
            class="fan-insta"
          >
            {post.instagram.startsWith('@') ? post.instagram : `@${post.instagram} `}
          </a>
        )
      }
    </div>
  </div>
</li>

<style>
    .fan-card {
        background: var(--color-bg-card);
        border: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        flex-direction: column;
        transition: var(--transition-fast), box-shadow 0.3s ease;
        width: 100%;
        border-radius: 2px;
        overflow: hidden;
        /*
        max-width: 300px;
        margin: 0 auto;*/
    }

    .card-image {
        width: 100%;
        aspect-ratio: 4 / 3;
        overflow: hidden;
        background: #000;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
        
    }

    .placeholder-img {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: #333;
        background: var(--color-brown-glass);
    }

    .card-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        flex-grow: 1;
    }

    .fan-message {
        font-style: italic;
        color: var(--color-text-muted);
        font-size: 0.95rem;
        margin: 0 0 1.5rem 0;
        line-height: 1.5;
        border-left: 2px solid var(--color-brown-solid);
        padding-left: 1rem;
    }

    .fan-footer {
        margin-top: auto;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding-top: 1rem;
    }

    .fan-name {
        display: block;
        font-weight: 700;
        color: var(--color-text-main);
        font-size: 0.9rem;
        letter-spacing: 0.5px;
    }

    .fan-insta {
        display: block;
        font-size: 0.8rem;
        color: #666;
        text-decoration: none;
        margin-top: 0.2rem;
        transition: color 0.2s;
    }

    .fan-insta:hover {
        color: var(--color-brown-solid);
        text-decoration: none;
    }

    @media (max-width: 600px) {
      .fan-card {
        flex-direction: row;
        align-items: stretch;
      }

      .card-image {
        width: 35%;
        aspect-ratio: auto;
        border-bottom: none;
        border-right: 1px solid rgba(0, 0, 0, 0.05);
      }
    }
</style>
