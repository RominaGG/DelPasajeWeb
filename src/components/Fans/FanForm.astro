---
import { contentfulClient } from "../../lib/contentful";
import FanCard from "./FanCard.astro";

const settingEntries = await contentfulClient.getEntries({
    content_type: 'globalSettings',
    limit: 1
})

const settings: any = settingEntries.items[0]?.fields || {};
const formLink = settings.linkFormCommunity || '#'

const entries = await contentfulClient.getEntries({
    content_type: 'fanPost',
    order: '-fields.date' as any,
});

const fanPosts = entries.items.map((item:any) => {
    const {name, message, instagram, image} = item.fields;
    return {
        id: item.sys.id,
        name, 
        message,
        instagram,
        image: image?.fields?.file?.url ? `https:${image.fields.file.url}` : null
    };
});

---

<section id="fans" class="section">
    <div class="main-container">

        <div class="fans-header">
            <h2 class="section-title">Comunidad</h2>
            <p class="fans-intro">
                Amigos pasajeros! Este es su espacio.
            </p>
        </div>

        <ul class="fans-grid">
            {fanPosts.length > 0 ? (
                fanPosts.map(post => (
                <FanCard post={post} />
            ))
        ): (
            <div class="no-posts-container">
            <p class="no-posts">Todavía no hay mensajes.</p>
            <p class="no-posts-sub">¡Sé el primero!</p>
        </div>
        )}
        </ul>

        <hr class="divider"/>

        <div class="join-wrapper">
            <div class="join-content">
                <h3 class="join-title">Si soy parte de tu ser...</h3>
                <p class="join-text">
                    Queremos verte. Mandanos tu foto en el show, tu tatuaje o simplemente
                    un mensaje de aguante.
                    Elegimos las mejores para subirlas a la web.
                </p>

                <a href={formLink}
                target="_blank"
                class="cta-btn"
                >
                SUBIR MI FOTO
            </a>
            </div>

            
        </div>
    </div>
</section>

<style>

    .fans-header {
        margin-bottom: 3rem;
    }

    .fans-intro {
        margin-top: -2rem;
        margin-bottom: 2rem;
        color: var(--color-text-muted);
        font-size: 1.1rem;
        max-width: 600px;
    }

    .fans-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 2rem;
        list-style: none;
        padding: 0;
        margin-bottom: 5rem;
    }

    .no-posts-container {
        grid-column: 1 / -1;
        text-align: center;
        padding: 4rem 2rem;
        border: 1px dashed rgba(255, 255, 255, 0.1);
        border-radius: 2px;
        background: var(--color-bg-card);
    }
    
    .np-posts {
        color: var(--color-text-main);
        font-size: 1.2rem;
        margin-bottom: 0.5rem;
    }

    .no-posts-sub {
        color: var(--color-text-muted);
    }



    .divider {
        border: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--color-brown-solid),transparent);
        margin: 4rem 0;
        opacity: 0.5;
    }

    .join-wrapper {
        background: var(--color-bg-card);
        border: 1px solid var(--color-brown-solid);
        padding: 4rem 2rem;
        text-align: center;
        display: flex;
        justify-content: center;
        border-radius: 2px;
        position: relative;
        overflow: hidden;
    }

    .join-wrapper::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    }

    .join-content {
        max-width: 600px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        position: relative;
        z-index: 2;

    }

    .join-title {
        font-family: var(--font-title);
        font-size: 2.5rem;
        margin: 0;
        color: var(--color-text-main);
        text-transform: uppercase;
    }

    .join-text {
        color: var(--color-text-muted);
        font-size: 1.1rem;
        line-height: 1.6;
    }

    .join-steps {
        display: flex;
        gap: 1.5rem;
        margin: 1rem 0 2rem 0;
        font-size: 0.9rem;
        color: var(--color-text-main);
        font-weight: 700;
        text-transform: uppercase;
        flex-wrap: wrap;
        justify-content: center;
    }

    .cta-btn {
        background-color: transparent;
        color: var(--color-text-main);
        text-decoration: none;
        padding: 1rem 3rem;
        font-weight: 800;
        font-size: 1.1rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        border: 2px solid var(--color-brown-solid);
        transition: var(--transition-fast);
        display: inline-block;
        border-radius: 2px;
        background: var(--color-brown-glass);
    }

    .cta-btn:hover {
        background-color: var(--color-brown-solid);
        color: var(--color-text-main);
        box-shadow: 0 0 25px var(--color-brown-glass);
        transform: translateY(-3px);
    }
    /*Responsive */

@media (max-width: 600px) {
    .fans-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    .join-wrapper {
        padding: 2.5rem 1.5rem;
    }

    .join-steps {
        flex-direction: column;
        gap: 0.5rem;
    }

    .cta-btn {
        width: 100%;
    }
    
}
</style>