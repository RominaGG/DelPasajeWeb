---
import { contentfulClient } from "../lib/contentful";
import { documentToHtmlString } from "@contentful/rich-text-html-renderer";
import {Image} from 'astro:assets'; 

const entries = await contentfulClient.getEntries({
  content_type: "homepage",
  limit: 1,
});

const homeData: any = entries.items[0]?.fields || {};

const aboutTitle = homeData.aboutTitle || "Nosotros";
let aboutImageUrl = "/assets/img/lineasdelocaso.jpg";
if (homeData.aboutImage?.fields?.file?.url) {
  aboutImageUrl = `https:${homeData.aboutImage.fields.file.url}`;
}

let aboutImageUrl2 = '/assets/img/barro_tapa.jpg';
if (homeData.aboutImageUrl2?.fields?.file?.url) {
  aboutImageUrl2 = `https:${homeData.aboutImageUrl2.fields.file.url}`;
} 

// Procesamos eel texto enriquecido
// convertimos el json de Contentful a html string

const rawRichText = homeData.aboutDescription;
const aboutHtmlString = rawRichText
  ? documentToHtmlString(rawRichText)
  : "<p>Informacion de la banda proximamente.</p>";
---

<section id="nosotros" class="section section-about">
  <div class="main-container">
    <div class="about-layout">
      <div class="about-text">
        <h2 class="section-title">{aboutTitle}</h2>

        <div class="rich-text-content" set:html={aboutHtmlString} />

        <div class="about-actions">
          <a href="/history" class="btn-history">Historia Completa</a>

          <a
            href="/assets/img/img4_.png"
            data-fslightbox="prensa"
            class="btn-press"
          >
            Archivo Prensa</a
          >
        </div>
        <div class="hidden">
          
          <a href="/assets/img/img5_.png" data-fslightbox="prensa"></a>
          <a href="/assets/img/img17_.png" data-fslightbox="prensa"></a>
          <a href="/assets/img/img11__.png" data-fslightbox="prensa"></a>
        </div>
      </div>

      <div class="about-flyer">
        <Image
         src={aboutImageUrl} 
         alt="Tapa disco Lineas del Ocaso" 
         width='300'
         height='300'
         class="img-back"
         loading='lazy'/>
        <Image 
        src={aboutImageUrl2} 
        alt="Tapa disco Barro"
        width='300'
        height='300'
        class="img-front"
        loading='lazy'/>
      </div>
    </div>
  </div>
</section>

<style>
  .about-layout {
    display: flex;
    align-items: flex-start;
    position: relative;
    gap: 4rem;
  }

  .about-text {
    max-width: 720px;
    padding-left: 2rem;
    background: none;
    position: relative;
    z-index: 2;
  }

  .about-text::before {
    content: "";
    position: absolute;
    left: 0;
    /*Movemos la linea de al lado del texto */
    top: 125px;
    height: 60%;
    width: 2px;
    background-color: var(--color-brown-solid);
  }
  .about-text .section-title {
    margin-bottom: 1.5rem;
    border: none;
    display: block;
    width: 100%;
    margin-left: -2rem;
    font-family: var(--font-title);
  }

  .rich-text-content {
    font-family: var(--font-body);
    color: var(--color-text-main);
    width: 100%;
  }
  .rich-text-content :global(p) {
    font-family: var(--font-body);
    font-size: 1.05rem;
    letter-spacing: 0.02rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .rich-text-content :global(strong),
  .rich-text-content :global(b) {
    color: var(--color-text-main);
    font-weight: 700;
  }

  .rich-text-content :global(ul) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .rich-text-content :global(li) {
    font-family: var(--font-body);
    margin-bottom: 0.5rem;
    color: var(--color-text-main);
  }

  .about-actions {
    display: flex;
    gap: 1.5rem;
    margin-top: 3rem;
    flex-wrap: wrap;
  }

  .btn-history {
    background: var(--color-brown-solid);
    color: white;
    padding: 0.8rem 2rem;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 1px;
    border-radius: 2px;
    transition: var(--transition-fast);
    border: 1px solid var(--color-brown-solid);
  }

  .btn-history:hover {
    background: transparent;
    color: white;
    box-shadow: 0 5px 15px rgba(97, 69, 58, 0.4);
    transform: translateY(-2px);
  }

  .btn-press {
    background: transparent;
    color: white;
    padding: 0.8rem 2rem;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 1px;
    border-radius: 2px;
    transition: var(--transition-fast);
    border: 1px solid rgba(255, 255, 255, 0.03);
  }

  .btn-press:hover {
    border-color: white;
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-2px);
  }

  .hidden {
    display: none;
  }

  .about-flyer {
    position: relative;
    margin-top: 4.5rem;
    z-index: 1;
    width: 320px;
    height: 320px;
  }
  .about-flyer img {
    position: absolute;
    width: 100%;
    max-width: 260px;
    filter: contrast(1.1);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
    border-radius: 4px;
  }

  .img-back {
    top: 0;
    right: 0;
    transform: rotate(8deg);
    opacity: 0.85;
    filter: contrast(1.1);
    z-index: 1;
  }
  
  .img-front {
    bottom: -70px;
    left: 80px;
    transform: rotate(-2deg) scale(1.05);
    opacity: 1;
    z-index: 2;
  }
  


  @media (max-width: 1024px) {
    .about-layout {
      gap: 2rem;
    }

    .about-text::before {
      display: none;
    }

    .about-flyer {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 0;
      pointer-events: none;
    }

    .about-text {
      /*position: relative;
        z-index: 1;*/
      background: rgba(0, 0, 0, 0.6);
      padding: 2rem;
    }
  }

  @media (max-width: 768px) {
    .about-layout {
      display: block;
      position: relative;
    }

    .about-flyer {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 0;
      pointer-events: none;
      margin-top: 0;
      width: 100%;
      height: 100%;
    }

    .about-flyer img {
      max-width: 240px;
      
    }
    .img-back {
      opacity: 0.15;
      transform: rotate(5deg) translate(20px, -30px);
    }

    .img-front {
      opacity: 0.15;
      transform: rotate(-8deg) translate(-20px, 30px);
    }

    .about-text {
      background: rgba(0, 0, 0, 0.6);
      padding: 2rem;
      border-radius: 2px;
      border: 1px solid rgba(255, 255, 255, 0.05);
      z-index: 1;
    }

    .btn-history,
    .btn-press {
      width: 100%;
      text-align: center;
    }

    .about-actions {
      gap: 1rem;
    }
  }

  @media (max-width: 480px) {
    .about-text {
      padding: 1.2rem;
    }
    .about-flyer img {
      max-width: 240px;
    }
  }
</style>
