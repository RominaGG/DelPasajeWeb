---
import { contentfulClient } from "../lib/contentful";

const year = new Date().getFullYear();

const entries = await contentfulClient.getEntries({
  content_type: 'globalSettings',
  limit: 1,
});

const settings: any = entries.items[0]?.fields || {};

interface SocialLink {
  name: string;
  url: string;
  icon: string;
}
const socialLinks: SocialLink[] = [];

if (settings.instagramUrl) {
  socialLinks.push({name: 'Instagram', url: settings.instagramUrl, icon: "/assets/icons/instagram.png"})
}

if (settings.youtubeUrl) {
  socialLinks.push({name: 'YouTube', url: settings.youtubeUrl, icon: "/assets/icons/youtube.png"})
}

if (settings.spotifyUrl) {
  socialLinks.push({name: 'Spotify', url: settings.spotifyUrl, icon: "/assets/icons/spotify.png"})
}

if (settings.deezerUrl) {
  socialLinks.push({name: 'Deezer', url: settings.dezzerUrl, icon: "/assets/icons/deezer.png"})
}

if (settings.amazonMusic) {
  socialLinks.push({name: 'Amazon Music', url: settings.amazonMusic, icon: "/assets/icons/amazon-music.png"})
}

if (settings.appleMusic) {
  socialLinks.push({name: 'Apple Music' , url: settings.applemusic, icon: "/assets/icons/apple-music.png"})
}
---

<footer class="footer">
  <div class="main-container footer-content">
    
<div class="footer-brand">
  <h3>DEL PASAJE  <span class="brand-mark">®</span></h3>
</div>

<ul class="footer-social">
  {socialLinks.map(link => (
    <li>
      <a href={link.url} target="_blank" rel="noopener" aria-label={link.name}>
        <img src={link.icon} alt={link.name} class="social-icon" />
      </a>
    </li>
  ))}
</ul>

<div class="footer-copy">
  <p>&copy; {year} Del Pasaje.</p>
  <p class="rights">Todos los derechos reservados.</p>
</div>


<div class="developer-credit">
  <p>Desarrollo:
    <a href="https://instagram.com/rominagarganog"
    target="_blank"
    rel="noopener">RGG</a>
  </p>
</div>
  </div>  
   
</footer>


<style>
  .footer {
    margin-top: 3rem;
    padding: 2rem 0 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    background: linear-gradient(to bottom, #000, #0a0a0a);
}

.footer-content {
    
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
}
.footer-brand h3 {
    font-family: var(--font-title);
    font-size: 1.8rem;
    color: var(--color-text-main);
    letter-spacing: 2px;
    margin: 0;
    text-transform: uppercase;
    opacity: 0.7;
}


.footer-social {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1.5rem;
}

.footer-social a {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 35px;
  height: 35px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.01);
  transition: var(--transition-fast);
}

.social-icon {
  width: 20px;
  height: 20px;
  object-fit: contain;
  opacity: 0.7;
  transition: var(--transition-fast);
  filter: invert(1);
}

.footer-social a:hover {
  background: var(--color-brown-solid);
  border-color: var(--color-brown-solid);
  transform: translateY(-3px);
  box-shadow: 0 5px 15px rgba(97, 69, 58, 0.04);
}

.footer-social a:hover .social-icon {
  opacity: 1;
  filter: invert(0);
}

.footer-copy {
  margin-top: 1rem;
  font-size: 0.85rem;
  color: var(--color-text-muted);
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.rights {
  font-size: 0.75rem;
  opacity: 0.6;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.brand-mark {
    font-size: 1rem;
    vertical-align: super;
    margin-left: 0.2rem;
    opacity: 0.8;
}

.developer-credit {
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  width: 50%;
}

.developer-credit p {
  font-size: 0.75rem;
  color: #555;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin: 0;

}

.developer-credit a {
  color: #888;
  text-decoration: none;
  font-weight: 700;
  transition: color 0.3s ease;
}

.developer-credit a:hover {
  color: var(--color-brown-solid);
}
@media (max-width: 600px) {
  .footer-social {
    gap: 1rem;
  }

  .footer-social a {
    width: 38px;
    height: 38px;
  }

  .developer-credit {
    width: 80%;
  }
}
</style>