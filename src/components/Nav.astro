---
import { contentfulClient } from "../lib/contentful";

const entries = await contentfulClient.getEntries( {
  content_type: 'globalSettings',
  limit: 1,
  select: ['fields.pressKit'] as any
});

const settingsData: any = entries.items[0]?.fields || {};
const pressKitFile = settingsData.pressKit;

const pressKitUrl = pressKitFile?.fields?.file?.url
? `https:${pressKitFile.fields.file.url}`
: null;

---



<nav class="nav">
  <div class="nav-inner">
    <a href="#inicio" class="logo-link"> 
      <img src="/assets/icons/DelPasajeLogoNegroEnPng.png" alt="Logo de Del pasaje"
      class="nav-logo"> </a>

      <button class="hamburger" aria-label="Abrir menú">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>

    <ul class="nav-links">
      <li><a href="#nosotros">Nosotros</a></li>
      <li><a href="#fechas">Fechas</a></li>
      <li><a href="#media">Videos</a></li>
      <li><a href="#galeria">Galeria</a></li>
      <li><a href="#fans">Comunidad</a></li>
      <li><a href="#contacto">Contacto</a></li>

      {pressKitUrl && (
        <li>
          <a href={pressKitUrl}
          target="_blank"
          download class="btn-press">
            <span>Gacetilla</span>
          </a>
        </li>
      )}
    </ul>
  </div>
</nav>


<script is:inline>

  const hamburger = document.querySelector('.hamburger');
  const navLinks = document.querySelector('.nav-links');
  const links = document.querySelectorAll('nav-links a');

  if (hamburger && navLinks) {
  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('active');
    navLinks?.classList.toggle('active');

  });
}
  document.querySelectorAll('.nav-links a').forEach(n => {
  n.addEventListener('click', () => {
    hamburger?.classList.remove('active');
    navLinks?.classList.remove('active')
  });
  });
</script>

<style>
  .nav {
  position: sticky;
  top: 0;
  z-index: 1000;
  height: 72px;
  background: var(--color-brown-glass);
  backdrop-filter: blur(6px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.nav-inner {
  height: 100%;
  width: 100%;
  max-width: 100%;
  margin: 0 auto;
  padding: 0 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.logo-link {
  display: flex;
  align-items: center;
  height: 100%;
  padding: 5px 0;
  z-index: 1002;
}

.nav-logo {
  height: 100%;
  max-height: 60px;
  width: auto;
  object-fit: contain;
  filter: invert(1) brightness(100%);
  transition: transform 0.3s ease;
  
}

.logo-link:hover .nav-log {
  transform: scale(1.05);
}

.nav-links {
  list-style: none;
  display: flex;
  gap: 1.5rem;
  
}

.nav-links a {
  text-decoration: none;
  color: var(--color-text-main);
  font-size: 1.5rem;
  position: relative;
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 500;
}

.nav-links a::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -4px;
  width: 0;
  height: 1px;
  background: var(--color-brown-glass);
  transition: width 0.3s ease;
}

.nav-links a:hover::after {
  width: 100%;
}

.hamburger {
  display: none;
  cursor: pointer;
  background: none;
  border: none;
  z-index: 1002;
  padding: 0.5rem;

}

.bar {
  display: block;
  width: 25px;
  height: 3px;
  margin: 5px auto;
  transition: all 0.3s ease-in-out;
  background-color: var(--color-text-muted);
}

@media (max-width: 1024px) {

  .nav-inner {
    padding: 0 1rem;
    justify-content: space-between;
  }
  .hamburger {
    display: block;
  }

  .nav-links {
    position: fixed;
    left: -100%;
    top: 0;
    flex-direction: column;
    background-color: var(--color-bg-card);
    width: 100%;
    height: 100vh;
    text-align: center;
    justify-content: center;
    padding-top: 0;
    gap: 2.5rem;
    z-index: 1001;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    transition: left 0.3s ease-in-out;
  }

  .nav-links.active {
    left: 0;
  }

  .nav-links li {
    margin: 1rem 0;
  }

  .nav-links a {
    font-size: 1.5rem;
  }

  .hamburger.active .bar:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active .bar:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .hamburger.active .bar:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

}


</style>
